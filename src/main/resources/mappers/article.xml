<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- namespace 속성은 해당 매퍼파일을 연결할 매퍼클래스(DAO) 설정(패키지포함) -->
<mapper namespace="kr.co.sboard.dao.ArticleDAO">

    <!-- id값은 DAO의 메서드명으로 맞춰줌 -->
    <select id="select">

    </select>

    <select id="selectAll">
        SELECT
        a.*,
        u.nick
        FROM Article a
        JOIN User u ON a.writer = u.userid
        ORDER BY a.ano DESC
        LIMIT #{pageRequestDTO.start}, 10;
    </select>

    <insert id="insert">
        INSERT INTO Article SET
        type='free',
        title=#{title},
        content=#{content},
        file=#{file},
        writer=#{writer},
        regip=#{regip},
        wdate=NOW();
    </insert>

    <select id="selectCountAll">
        SELECT COUNT(*) FROM Article;
    </select>

    <update id="update">

    </update>

    <delete id="delete">

    </delete>
</mapper>